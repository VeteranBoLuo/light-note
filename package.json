{
  "name": "light-note",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "qs@<6.15.2": "6.15.3",
      "cookie@<0.7.0": "0.7.2"
    }
  },
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "dev:server": "pnpm --filter server start",
    "test": "pnpm -r test",
    "typecheck": "pnpm --filter web typecheck",
    "deploy:all": "bash scripts/deploy.sh",
    "deploy:web": "bash scripts/deploy-web.sh",
    "deploy:server": "bash scripts/deploy-server.sh"
  }
}
